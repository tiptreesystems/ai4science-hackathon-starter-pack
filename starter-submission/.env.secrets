# Optional Claude Code settings.
# This file is sourced by run.sh before the submission starts.
#
# The hackathon LiteLLM gateway is no longer active. For normal local runs,
# use a direct provider key and leave ANTHROPIC_BASE_URL unset:
#
# ANTHROPIC_API_KEY=...
# CLAUDE_MODEL=...
#
# If you operate your own Anthropic-compatible gateway, set its base URL:
#
# ANTHROPIC_BASE_URL=https://your-gateway.example.com
#
# Keep this enabled for Anthropic-compatible gateway endpoints. It avoids
# sending Claude Code beta fields that some proxies reject.
# CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1
