# Optional Claude Code / LiteLLM settings.
# This file is sourced by run.sh before the submission starts.
#
# For organizer-provided LiteLLM keys, uncomment and fill in:
#
# ANTHROPIC_API_KEY=sk-...
# ANTHROPIC_BASE_URL=https://hackathon.tiptreesystems.com/litellm
# CLAUDE_MODEL=bedrock-claude-sonnet
#
# Other available models may include:
# CLAUDE_MODEL=bedrock-claude-opus
# CLAUDE_MODEL=bedrock-claude-haiku
#
# Keep this enabled for Anthropic-compatible LiteLLM endpoints.
# It avoids sending Claude Code beta fields that some proxies reject.
# CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1
